{
  "name": "hr-letter-management-api",
  "version": "1.0.0",
  "description": "Production-ready NestJS backend API for HR letter management.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "templates:docx": "node scripts/generate-docx-templates.js && node scripts/standardize-docx-header-footer.js",
    "templates:footer": "node scripts/standardize-docx-header-footer.js",
    "templates:layout": "node scripts/standardize-docx-header-footer.js",
    "templates:audit": "node scripts/audit-docx-style.js",
    "import:outgoing-letters:2026": "node scripts/import-outgoing-letter-numbers-2026.js",
    "migrate:letter-master:2026": "node scripts/migrate-letter-master-2026.js",
    "import:master-docx-templates": "node scripts/import-master-docx-templates.js && node scripts/standardize-docx-header-footer.js",
    "templates:global-numbering": "node scripts/migrate-global-numbering-templates.js",
    "templates:kk01": "node scripts/update-kk01-template.js && node scripts/standardize-docx-header-footer.js",
    "templates:kk02": "node scripts/update-kk02-template.js && node scripts/standardize-docx-header-footer.js",
    "templates:offering": "node scripts/update-offering-letter-template.js && node scripts/standardize-docx-header-footer.js",
    "templates:se": "node scripts/update-se-template.js && node scripts/standardize-docx-header-footer.js",
    "test:offering": "node scripts/test-offering-letter-regression.js",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@prisma/client": "^6.1.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "docxtemplater": "^3.54.0",
    "helmet": "^8.0.0",
    "jodit-vue": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "nestjs-pino": "^4.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pizzip": "^3.1.7",
    "puppeteer": "^23.10.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "mammoth": "^1.12.0",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
