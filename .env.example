NODE_ENV=development
APP_NAME="HR Letter Management API"
PORT=3000
API_URL=http://localhost:3000/api
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hr_letters?schema=public

JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12
STORAGE_PATH=./storage
DOCX_TEMPLATE_PATH=./storage/templates
GENERATED_DOC_PATH=./storage/generated
LIBREOFFICE_BIN=soffice

SWAGGER_ENABLED=true
SWAGGER_PATH=docs
